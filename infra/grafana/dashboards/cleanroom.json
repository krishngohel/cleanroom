{
  "title": "Cleanroom AI — Privacy Dashboard",
  "uid": "cleanroom-privacy",
  "version": 1,
  "panels": [
    {
      "id": 1, "type": "timeseries",
      "title": "Privacy Budget Burn Rate (epsilon per org)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "cleanroom_epsilon_spent_total", "legendFormat": "{{org_id}}"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [
        {"color": "green", "value": null},
        {"color": "yellow", "value": 6},
        {"color": "red", "value": 8}
      ]}}}
    },
    {
      "id": 2, "type": "stat",
      "title": "Budget Exhausted Orgs",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "cleanroom_budget_exhausted_orgs"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [
        {"color": "green", "value": null},
        {"color": "red", "value": 1}
      ]}}}
    },
    {
      "id": 3, "type": "counter",
      "title": "Total Rounds Completed",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "cleanroom_rounds_completed_total"}]
    },
    {
      "id": 4, "type": "histogram",
      "title": "Aggregation Duration (seconds)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "rate(cleanroom_aggregation_duration_seconds_bucket[5m])"}]
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "10s",
  "schemaVersion": 39
}
